[Unit]
Description = User Service

[Service]
User=roboshop
Environment=MONGO=true
Environment=REDIS_URL='redis://redis.sh.nagendrablog.site:6379'
Environment=MONGO_URL="mongodb://mongodb.sh.nagendrablog.site:27017/users"
ExecStart=/usr/bin/node /app/server.js
SyslogIdentifier=user

[Install]
WantedBy=multi-user.target